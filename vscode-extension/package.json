{
  "name": "kleidi-task",
  "displayName": "Kvik Tasks",
  "description": "Task sidebar for kleidi-task — view, filter, and insert tasks into your workflow",
  "version": "0.1.0",
  "publisher": "ahoylog",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",

  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kleidi-task",
          "title": "Kvik Tasks",
          "icon": "$(checklist)"
        }
      ]
    },
    "views": {
      "kleidi-task": [
        {
          "id": "kleidiTask",
          "name": "Tasks"
        }
      ]
    },
    "commands": [
      {
        "command": "kleidiTask.refresh",
        "title": "Refresh Tasks",
        "icon": "$(refresh)",
        "category": "Kvik Tasks"
      },
      {
        "command": "kleidiTask.insertToTerminal",
        "title": "Insert to Terminal",
        "icon": "$(terminal)",
        "category": "Kvik Tasks"
      },
      {
        "command": "kleidiTask.openInBrowser",
        "title": "Open in Browser",
        "icon": "$(link-external)",
        "category": "Kvik Tasks"
      },
      {
        "command": "kleidiTask.copyReference",
        "title": "Copy Reference",
        "icon": "$(copy)",
        "category": "Kvik Tasks"
      },
      {
        "command": "kleidiTask.filterTodo",
        "title": "Show Todo",
        "category": "Kvik Tasks"
      },
      {
        "command": "kleidiTask.filterDoing",
        "title": "Show Doing",
        "category": "Kvik Tasks"
      },
      {
        "command": "kleidiTask.filterAll",
        "title": "Show All",
        "category": "Kvik Tasks"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "kleidiTask.refresh",
          "when": "view == kleidiTask",
          "group": "navigation"
        },
        {
          "command": "kleidiTask.filterTodo",
          "when": "view == kleidiTask"
        },
        {
          "command": "kleidiTask.filterDoing",
          "when": "view == kleidiTask"
        },
        {
          "command": "kleidiTask.filterAll",
          "when": "view == kleidiTask"
        }
      ],
      "view/item/context": [
        {
          "command": "kleidiTask.insertToTerminal",
          "when": "view == kleidiTask",
          "group": "inline"
        },
        {
          "command": "kleidiTask.openInBrowser",
          "when": "view == kleidiTask"
        },
        {
          "command": "kleidiTask.copyReference",
          "when": "view == kleidiTask"
        }
      ]
    },
    "configuration": {
      "title": "Kvik Tasks",
      "properties": {
        "kleidiTask.serverUrl": {
          "type": "string",
          "default": "http://localhost:7842",
          "description": "URL of the klt serve instance"
        },
        "kleidiTask.refreshInterval": {
          "type": "number",
          "default": 10,
          "description": "Auto-refresh interval in seconds (0 to disable)"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
