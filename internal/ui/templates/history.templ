package templates

import "github.com/tomas-chudjak/kleidi-task/internal/core"
import "fmt"

templ HistoryPage(project core.Project, task core.Task, history []core.HistoryEntry, workflows []core.WorkflowDef) {
	@Layout(fmt.Sprintf("#%d History", task.ID), project.Slug) {
		<div class="klt-toolbar">
			<div class="klt-toolbar-left">
				<a href={ templ.SafeURL(fmt.Sprintf("/p/%s/t/%d", project.Slug, task.ID)) } class="klt-back-link"><i class="icon icon-arrow-left"></i></a>
				@TypeBadge(string(task.Type), workflows)
				<span class="klt-toolbar-id">#{ fmt.Sprintf("%d", task.ID) }</span>
				<span style="color:var(--klt-fg-muted);">{ task.Title }</span>
			</div>
		</div>

		<div class="klt-task-layout">
			<div class="klt-task-main">
				<div class="klt-detail-card">
					<h4 class="klt-detail-card-title"><i class="icon icon-clock"></i> Workflow History ({ fmt.Sprintf("%d", len(history)) } entries)</h4>
					if len(history) == 0 {
						<div class="klt-empty">No workflow history for this task.</div>
					} else {
						<div class="klt-timeline">
							for _, h := range history {
								<div class={ "klt-timeline-entry" + timelineEntryClass(h.Success) }>
									<div class="klt-timeline-dot"></div>
									<div class="klt-timeline-content">
										<div class="klt-timeline-header">
											<span class="klt-timeline-phase">{ h.Phase }</span>
											<span class="klt-timeline-action">{ h.Action }</span>
											if h.ActionType != "none" && h.ActionType != "" {
												<span class="klt-badge klt-badge-todo" style="font-size:0.55rem;">{ h.ActionType }</span>
											}
											if h.DurationMs > 0 {
												<span class="klt-timeline-duration">{ fmt.Sprintf("%dms", h.DurationMs) }</span>
											}
											if !h.Success {
												<span class="klt-badge" style="background:#fde8ee;color:var(--klt-danger);font-size:0.55rem;">FAILED</span>
											}
											<span class="klt-timeline-time">{ h.CreatedAt.Format("2006-01-02 15:04:05") }</span>
										</div>
										if h.Output != "" {
											<pre class="klt-timeline-output">{ h.Output }</pre>
										}
									</div>
								</div>
							}
						</div>
					}
				</div>
			</div>
		</div>
	}
}
