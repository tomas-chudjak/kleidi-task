package templates

import "github.com/tomas-chudjak/kleidi-task/internal/core"
import "fmt"

type DashboardProject struct {
	Project  core.Project
	Stats    core.ProjectStats
	ExtStats core.ExtendedStats
}

type GlobalStats struct {
	Todo              int64
	Doing             int64
	Done              int64
	BugsOpen          int64
	CompletedThisWeek int64
	Total             int64
}

templ Dashboard(projects []DashboardProject, global GlobalStats) {
	@LayoutMinimal("Dashboard") {
		<h2 class="klt-title">Dashboard</h2>

		if len(projects) == 0 {
			<div class="klt-card klt-empty">
				<p>No projects registered.</p>
				<p>Run <code>klt init</code> in a project directory to get started.</p>
			</div>
		} else {
			<!-- Global stats -->
			<div class="k-grid k-grid--12 klt-global-stats">
				<div class="k-col-span-2 klt-global-stat">
					<div class="klt-global-stat-value">{ fmt.Sprintf("%d", global.Total) }</div>
					<div class="klt-global-stat-label">Total tasks</div>
				</div>
				<div class="k-col-span-2 klt-global-stat">
					<div class="klt-global-stat-value">{ fmt.Sprintf("%d", global.Todo) }</div>
					<div class="klt-global-stat-label">Todo</div>
				</div>
				<div class="k-col-span-2 klt-global-stat">
					<div class="klt-global-stat-value">{ fmt.Sprintf("%d", global.Doing) }</div>
					<div class="klt-global-stat-label">In progress</div>
				</div>
				<div class="k-col-span-2 klt-global-stat">
					<div class="klt-global-stat-value">{ fmt.Sprintf("%d", global.Done) }</div>
					<div class="klt-global-stat-label">Done</div>
				</div>
				<div class="k-col-span-2 klt-global-stat">
					<div class="klt-global-stat-value klt-global-stat-value--accent">{ fmt.Sprintf("%d", global.CompletedThisWeek) }</div>
					<div class="klt-global-stat-label">This week</div>
				</div>
				if global.BugsOpen > 0 {
					<div class="k-col-span-2 klt-global-stat">
						<div class="klt-global-stat-value klt-global-stat-value--danger">{ fmt.Sprintf("%d", global.BugsOpen) }</div>
						<div class="klt-global-stat-label">Open bugs</div>
					</div>
				}
			</div>

			<!-- Projects -->
			<h3 class="klt-section-title">Projects</h3>
			<div class="klt-projects-grid">
				for _, dp := range projects {
					@ProjectCard(dp)
				}
			</div>

			<!-- Recent activity across all projects -->
			@RecentActivity(projects)
		}
	}
}

templ ProjectCard(dp DashboardProject) {
	<a href={ templ.SafeURL("/p/" + dp.Project.Slug) } class="klt-project-card">
		<div class="klt-project-name">{ dp.Project.Name }</div>
		<div class="klt-project-meta">{ dp.Project.Slug }</div>
		<!-- Type breakdown bar -->
		if dp.ExtStats.Total > 0 {
			<div class="klt-type-bar">
				for _, tc := range dp.ExtStats.TypeBreakdown {
					<div class={ "klt-type-bar-seg klt-type-bar-seg--" + string(tc.Type) } style={ fmt.Sprintf("width:%.0f%%", float64(tc.Count)/float64(dp.ExtStats.Total)*100) } title={ fmt.Sprintf("%s: %d", tc.Type, tc.Count) }></div>
				}
			</div>
		}
		<div class="klt-project-stats-row">
			<div class="klt-mini-stat">
				<span class="klt-mini-stat-value">{ fmt.Sprintf("%d", dp.Stats.Todo) }</span>
				<span class="klt-mini-stat-label">todo</span>
			</div>
			<div class="klt-mini-stat">
				<span class="klt-mini-stat-value">{ fmt.Sprintf("%d", dp.Stats.Doing) }</span>
				<span class="klt-mini-stat-label">doing</span>
			</div>
			<div class="klt-mini-stat">
				<span class="klt-mini-stat-value">{ fmt.Sprintf("%d", dp.Stats.Done) }</span>
				<span class="klt-mini-stat-label">done</span>
			</div>
			if dp.Stats.BugsOpen > 0 {
				<div class="klt-mini-stat klt-mini-stat--danger">
					<span class="klt-mini-stat-value">{ fmt.Sprintf("%d", dp.Stats.BugsOpen) }</span>
					<span class="klt-mini-stat-label">bugs</span>
				</div>
			}
		</div>
		if dp.ExtStats.CompletedThisWeek > 0 {
			<div class="klt-project-velocity">
				<i class="icon icon-trending-up"></i> { fmt.Sprintf("%d", dp.ExtStats.CompletedThisWeek) } this week
			</div>
		}
	</a>
}

templ RecentActivity(projects []DashboardProject) {
	<!-- Collect recent completed from all projects -->
	<h3 class="klt-section-title">Recent completions</h3>
	<div class="klt-recent-list">
		for _, dp := range projects {
			for _, t := range dp.ExtStats.RecentCompleted {
				<div class="klt-recent-row">
					<span class="klt-recent-check"><i class="icon icon-check-circle"></i></span>
					<a href={ templ.SafeURL(fmt.Sprintf("/p/%s/t/%d", dp.Project.Slug, t.ID)) } class="klt-recent-title">{ t.Title }</a>
					<span class="klt-recent-project">{ dp.Project.Name }</span>
					if t.CompletedAt != nil {
						<span class="klt-recent-date">{ t.CompletedAt.Format("Jan 2 15:04") }</span>
					}
				</div>
			}
		}
	</div>
}
