package templates

import "github.com/tomas-chudjak/kleidi-task/internal/core"
import "fmt"

func boardTypeURL(slug, typ, current string) string {
	if typ == "" {
		return "/p/" + slug + "/board"
	}
	toggled := toggleFilter(current, typ)
	if toggled == "" {
		return "/p/" + slug + "/board"
	}
	return "/p/" + slug + "/board?type=" + toggled
}

templ BoardPage(project core.Project, todo []core.Task, doing []core.Task, done []core.Task, stats core.ProjectStats, typeFilter string, workflows []core.WorkflowDef) {
	@Layout(project.Name+" — Board", project.Slug) {
		<div class="klt-board-header">
			<h2 class="klt-title">{ project.Name }</h2>
			<div class="klt-view-toggle">
				<a href={ templ.SafeURL("/p/" + project.Slug) } class="klt-view-btn">
					<i class="icon icon-list"></i> List
				</a>
				<a href={ templ.SafeURL("/p/" + project.Slug + "/board") } class="klt-view-btn klt-view-btn--active">
					<i class="icon icon-columns-3"></i> Board
				</a>
			</div>
		</div>

		@StatsBar(stats)

		<!-- Type filter for board -->
		<div class="klt-filters" style="margin-bottom: 12px;">
			<a href={ templ.SafeURL(boardTypeURL(project.Slug, "", typeFilter)) } class={ filterClass(typeFilter == "") }>All types</a>
			<a href={ templ.SafeURL(boardTypeURL(project.Slug, "task", typeFilter)) } class={ filterClass(hasFilter(typeFilter, "task")) }>Tasks</a>
			<a href={ templ.SafeURL(boardTypeURL(project.Slug, "bug", typeFilter)) } class={ filterClass(hasFilter(typeFilter, "bug")) }>Bugs</a>
			<a href={ templ.SafeURL(boardTypeURL(project.Slug, "feature", typeFilter)) } class={ filterClass(hasFilter(typeFilter, "feature")) }>Features</a>
			<a href={ templ.SafeURL(boardTypeURL(project.Slug, "hotfix", typeFilter)) } class={ filterClass(hasFilter(typeFilter, "hotfix")) }>Hotfixes</a>
		</div>

		<div class="k-grid k-grid--3 klt-board">
			@BoardColumn("Todo", "todo", todo, project.Slug, workflows)
			@BoardColumn("In Progress", "doing", doing, project.Slug, workflows)
			@BoardColumn("Done", "done", done, project.Slug, workflows)
		</div>

		<script src="/static/js/sortable.min.js"></script>
		@boardScript()
	}
}

script boardScript() {
	document.querySelectorAll('.klt-board-cards').forEach(function(el) {
		new Sortable(el, {
			group: 'kanban',
			animation: 150,
			ghostClass: 'klt-card-ghost',
			dragClass: 'klt-card-drag',
			onEnd: function(evt) {
				var taskId = evt.item.dataset.taskId;
				var newStatus = evt.to.dataset.status;
				fetch('/p/' + evt.to.dataset.slug + '/tasks/' + taskId + '/move', {
					method: 'POST',
					headers: {'Content-Type': 'application/json'},
					body: JSON.stringify({status: newStatus})
				}).then(function(res) {
					return res.text();
				}).then(function(html) {
					// Process OOB stats update
					if (html.trim()) {
						var parser = new DOMParser();
						var doc = parser.parseFromString(html, 'text/html');
						var oob = doc.querySelector('[hx-swap-oob]');
						if (oob) {
							var target = document.getElementById(oob.id);
							if (target) {
								oob.removeAttribute('hx-swap-oob');
								target.replaceWith(oob);
							}
						}
					}
					// Update column counts
					document.querySelectorAll('.klt-board-cards').forEach(function(col) {
						var count = col.children.length;
						col.closest('.klt-board-column').querySelector('.klt-board-count').textContent = count;
					});
				});
			}
		});
	});
}

templ BoardColumn(title string, status string, tasks []core.Task, slug string, workflows []core.WorkflowDef) {
	<div class={ "klt-board-column klt-board-column--" + status }>
		<div class="klt-board-column-header">
			<span class={ "klt-board-dot klt-board-dot--" + status }></span>
			<span class="klt-board-column-title">{ title }</span>
			<span class="klt-board-count">{ fmt.Sprintf("%d", len(tasks)) }</span>
		</div>
		<div class="klt-board-cards" data-status={ status } data-slug={ slug }>
			for _, t := range tasks {
				@BoardCard(t, slug, workflows)
			}
		</div>
	</div>
}

templ BoardCard(task core.Task, slug string, workflows []core.WorkflowDef) {
	<div class={ "klt-board-card klt-board-card--" + string(task.Type) } data-task-id={ fmt.Sprintf("%d", task.ID) }>
		<div class="klt-board-card-top">
			@TypeBadge(string(task.Type), workflows)
			<span class="klt-board-card-id">#{ fmt.Sprintf("%d", task.ID) }</span>
		</div>
		<a href={ templ.SafeURL(fmt.Sprintf("/p/%s/t/%d", slug, task.ID)) } class="klt-board-card-title">{ task.Title }</a>
		if task.Priority > 0 || task.Category != "" {
			<div class="klt-board-card-meta">
				if task.Category != "" {
					<span class="klt-category-tag">{ task.Category }</span>
				}
				if task.Priority > 0 {
					<span class="klt-task-priority">P{ fmt.Sprintf("%d", task.Priority) }</span>
				}
			</div>
		}
	</div>
}
