package templates

import "github.com/tomas-chudjak/kleidi-task/internal/core"
import "fmt"
import "strings"

templ WorkflowsPage(project core.Project, workflows []core.WorkflowDef) {
	@Layout("Workflows — "+project.Name, project.Slug) {
		<div class="klt-board-header">
			<h2 class="klt-title"><i class="icon icon-git-branch"></i> Workflows</h2>
		</div>

		<div class="k-grid k-grid--12 klt-project-grid">
			<div class="k-col-span-9 klt-project-main">
				<div class="klt-task-list">
					for _, wf := range workflows {
						<div class="klt-task-row" style="grid-template-columns: 5.5rem 1fr 8rem 4.5rem;">
							@TypeBadge(wf.TaskType, workflows)
							<span class="klt-task-title" style="cursor:default;">{ strings.Join(wf.Phases, " → ") }</span>
							<span class="klt-task-status">{ fmt.Sprintf("%d phases", len(wf.Phases)) }</span>
							<div class="klt-task-actions" style="opacity:1;">
								<a href={ templ.SafeURL(fmt.Sprintf("/p/%s/workflows/%s", project.Slug, wf.TaskType)) } class="klt-btn-done" style="opacity:1;" title="Edit workflow">
									<i class="icon icon-pencil"></i>
								</a>
								if !wf.IsBuiltin {
									<button
										class="klt-cat-del-btn"
										hx-delete={ fmt.Sprintf("/p/%s/workflows/%s", project.Slug, wf.TaskType) }
										hx-target="body"
										hx-swap="outerHTML"
										hx-confirm={ fmt.Sprintf("Delete task type '%s' and its workflow?", wf.TaskType) }
										title="Delete type"
									>
										<i class="icon icon-trash-2"></i>
									</button>
								}
							</div>
						</div>
					}
				</div>

				<!-- Create new task type -->
				<div class="klt-detail-card" style="margin-top:1rem;">
					<h3 class="klt-settings-heading" style="margin-bottom:0.75rem;">Create custom task type</h3>
					<form
						hx-post={ "/p/" + project.Slug + "/workflows" }
						hx-target="body"
						hx-swap="outerHTML"
						hx-ext="json-enc"
						class="klt-cat-form"
					>
						<div class="klt-cat-form-row">
							<input type="text" name="task_type" placeholder="Type name (e.g. spike)" required autocomplete="off" data-1p-ignore data-lpignore="true" data-form-type="other" class="klt-cat-input" pattern="[a-z][a-z0-9-]*" title="Lowercase letters, numbers, and hyphens"/>
							<input type="text" name="prefix" placeholder="PREFIX (optional)" autocomplete="off" data-1p-ignore data-lpignore="true" data-form-type="other" class="klt-cat-input" style="max-width:120px;" title="Title prefix for auto-detection (e.g. SPIKE)"/>
							<input type="color" name="color" value="#e0e7ef" class="klt-cat-color"/>
							<button type="submit" class="klt-cat-add-btn" title="Create type"><i class="icon icon-plus"></i></button>
						</div>
					</form>
				</div>
			</div>
		</div>
	}
}
