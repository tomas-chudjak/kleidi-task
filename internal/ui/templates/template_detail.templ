package templates

import "github.com/tomas-chudjak/kleidi-task/internal/core"
import "fmt"

templ TemplateDetailPage(project core.Project, tpl core.TaskTemplate, workflows []core.WorkflowDef) {
	@Layout(tpl.Name+" — Template", project.Slug) {
		<div data-slug={ project.Slug }></div>
		<!-- Toolbar -->
		<div class="klt-toolbar">
			<div class="klt-toolbar-left">
				<a href={ templ.SafeURL("/p/" + project.Slug + "/settings#templates") } class="klt-back-link"><i class="icon icon-arrow-left"></i></a>
				@TypeBadge(tpl.Type, workflows)
				<span class="klt-toolbar-id">Template: { tpl.Name }</span>
			</div>
			<div class="klt-toolbar-right">
				<a
					href={ templ.SafeURL(fmt.Sprintf("/p/%s/templates/%d/delete", project.Slug, tpl.ID)) }
					class="klt-toolbar-btn klt-toolbar-btn--danger"
					onclick="return confirm('Delete this template?')"
				>
					<i class="icon icon-trash-2"></i> Delete
				</a>
			</div>
		</div>

		<!-- Save indicator -->
		<div id="save-indicator" class="klt-save-indicator"></div>

		<!-- Two-column layout -->
		<form
			id="tpl-form"
			hx-patch={ fmt.Sprintf("/p/%s/templates/%d", project.Slug, tpl.ID) }
			hx-ext="json-enc"
			hx-swap="none"
		>
		<div class="klt-task-layout">
			<!-- Main content -->
			<div class="klt-task-main" style="display:flex;flex-direction:column;gap:16px;">
					<div class="klt-detail-card">
						<div class="klt-field" style="margin-bottom:16px;">
							<label class="klt-field-label" for="tpl-name">Name</label>
							<input type="text" class="klt-input klt-input--title" id="tpl-name" name="name" value={ tpl.Name } required autocomplete="off" data-1p-ignore data-lpignore="true" data-form-type="other"/>
						</div>
						<div class="klt-field">
							<label class="klt-field-label" for="tpl-desc-editor">Description template</label>
							<textarea
								class="klt-textarea"
								id="tpl-desc-editor"
								name="description"
								rows="10"
								placeholder="Template description content..."
							>{ tpl.Description }</textarea>
							<script>
								(function() {
									var ta = document.getElementById('tpl-desc-editor');
									if (ta && typeof EasyMDE !== 'undefined') {
										var mde = new EasyMDE({
											element: ta,
											spellChecker: false,
											status: false,
											placeholder: 'Template description content...',
											toolbar: ['bold', 'italic', 'heading', '|', 'unordered-list', 'ordered-list', 'checklist', '|', 'code', 'quote', 'link', '|', 'preview', 'side-by-side'],
											sideBySideFullscreen: false,
											minHeight: '200px',
										});
										document.getElementById('tpl-form').addEventListener('htmx:configRequest', function(e) {
											e.detail.parameters.description = mde.value();
										});
									}
								})();
							</script>
						</div>
					</div>
			</div>

			<!-- Sidebar -->
			<div class="klt-task-sidebar">
				<button type="submit" class="klt-add-btn" style="width:100%;">
					<i class="icon icon-check"></i> Save template
				</button>
				<div class="klt-detail-card">
					<div class="klt-detail-fields">
						<div class="klt-field">
							<label class="klt-field-label">Type</label>
							<div class="klt-select-wrap">
								<select class="klt-select" id="tpl-type" name="type">
									@TypeOptions(tpl.Type, workflows)
								</select>
								<i class="icon icon-chevron-down klt-select-icon"></i>
							</div>
						</div>
						<div class="klt-field">
							<label class="klt-field-label">Default priority</label>
							<input type="number" class="klt-input" name="priority" value={ fmt.Sprintf("%d", tpl.Priority) } min="0"/>
						</div>
						<div class="klt-field">
							<label class="klt-field-label">Created</label>
							<div class="klt-field-value klt-field-value--mono">{ tpl.CreatedAt.Format("2006-01-02 15:04") }</div>
						</div>
					</div>
				</div>
			</div>
		</div>
		</form>
	}
}
